generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../aitk_db.db"
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Queue {
  id         Int     @id @default(autoincrement())
  gpu_ids    String  @unique
  is_running Boolean @default(false)

  @@index([gpu_ids])
}

model Job {
  id              String   @id @default(uuid())
  name            String   @unique
  gpu_ids         String
  job_config      String // JSON string
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  status          String   @default("stopped")
  stop            Boolean  @default(false)
  return_to_queue Boolean  @default(false) // same as stop, but will be set to 'queued' when stopped
  step            Int      @default(0)
  info            String   @default("")
  speed_string    String   @default("")
  queue_position  Int      @default(0)
  pid             Int?
  job_type        String   @default("train") // 'train', 'caption'
  job_ref         String? // can be used for anything for special jobs, like dataset path for caption jobs

  @@index([status])
  @@index([gpu_ids])
  @@index([job_type])
  @@index([job_ref])

  flow_grpo_vote_tasks FlowGRPOVoteTask[]
  flow_grpo_candidates FlowGRPOCandidate[]
  flow_grpo_votes      FlowGRPOVote[]
}

model FlowGRPOVoteTask {
  id              String   @id @default(uuid())
  job_id          String
  prompt          String
  negative_prompt String   @default("")
  width           Int?
  height          Int?
  seed            Int?
  guidance_scale  Float?
  num_inference_steps Int?
  sampler         String?
  scheduler       String?
  error           String?
  status          String   @default("requested")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  job        Job                 @relation(fields: [job_id], references: [id], onDelete: Cascade)
  candidates FlowGRPOCandidate[]
  votes      FlowGRPOVote[]

  @@index([job_id, status, created_at])
}

model FlowGRPOCandidate {
  id                  String   @id @default(uuid())
  job_id              String
  vote_task_id        String
  order_index         Int
  prompt              String
  negative_prompt     String   @default("")
  seed                Int
  guidance_scale      Float
  num_inference_steps Int
  sampler             String
  scheduler           String
  image_path          String
  state_path          String
  status              String   @default("open")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  job       Job              @relation(fields: [job_id], references: [id], onDelete: Cascade)
  vote_task FlowGRPOVoteTask @relation(fields: [vote_task_id], references: [id], onDelete: Cascade)
  votes     FlowGRPOVote[]

  @@index([job_id, vote_task_id, order_index])
}

model FlowGRPOVote {
  id           String   @id @default(uuid())
  job_id       String
  vote_task_id String
  candidate_id String?
  value        String
  reward       Float
  processed    Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  job       Job              @relation(fields: [job_id], references: [id], onDelete: Cascade)
  vote_task FlowGRPOVoteTask @relation(fields: [vote_task_id], references: [id], onDelete: Cascade)
  candidate FlowGRPOCandidate? @relation(fields: [candidate_id], references: [id], onDelete: Cascade)

  @@index([job_id, processed, created_at])
  @@index([vote_task_id, processed])
}
