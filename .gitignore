# --- Private training configs ------------------------------------------
# config/examples/ is private-by-default: every config you write (artist
# names, dataset paths, recipes) is ignored automatically. Only the
# upstream-shipped example configs below are public. To publish a new
# example deliberately, add a matching '!' line here (or git add -f).
/config/examples/*
